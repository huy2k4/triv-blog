{{!-- ═══════════════════════════════════════
     View: my-days.hbs
     Props:
       categoryName        string
       posts               Array<{ slug, date, displayDate, title, excerpt, tagClass, tagName }>
═══════════════════════════════════════ --}}

<header class="page-header">
  <div class="page-header-inner">
    <h1 class="page-title" data-i18n="cat.my-days">{{categoryName}}</h1>
  </div>
</header>

<section class="bento-grid container">
  
  <!-- Vùng 60% (2x4 trên lưới 4 cột = chiếm 2 cột, trải dài 4 hàng) hoặc 4x4 tuỳ ý -->
  <!-- Vì My Days có danh sách Timeline dài, để nó chiếm 2 cột (span 2) hoặc 3 cột. Ở lưới 4 cột, cho Timeline là cell-2x4 -->
  <div class="bento-cell cell-2x4">
    <h2 class="widget-title">Dòng thời gian</h2>
    <div class="timeline-list">
      {{#if posts.length}}
        {{#each posts}}
        <div class="timeline-item reveal">
          <div class="timeline-date">{{displayDate}}</div>
          <div class="timeline-content">
            <a href="/bai-viet/{{slug}}" class="timeline-title">{{title}}</a>
            {{#if excerpt}}
            <p class="timeline-excerpt">{{excerpt}}</p>
            {{/if}}
          </div>
        </div>
        {{/each}}
      {{else}}
        <div class="empty-state" role="status">
          <span class="empty-ornament" aria-hidden="true">✦</span>
          <p class="empty-title" data-i18n="empty.title">Chưa có bài viết nào...</p>
        </div>
      {{/if}}
    </div>
  </div>

  <!-- Reading (2x2) -->
  <div class="bento-cell cell-2x2 cell-soul reveal">
    <div class="soul-icon" aria-label="Đang đọc">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"></path>
      </svg>
    </div>
    <div class="soul-text">Norwegian Wood</div>
  </div>

  <!-- Listening (2x2) -->
  <div class="bento-cell cell-2x2 cell-soul reveal">
    <div class="soul-icon" aria-label="Đang nghe">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="5.5" cy="17.5" r="2.5"></circle>
        <circle cx="17.5" cy="15.5" r="2.5"></circle>
        <path d="M8 17V5l12-2v12"></path>
        <path d="M8 9l12-2"></path>
      </svg>
    </div>
    <div class="soul-text">Và thế là hết - Chillies</div>
  </div>

  <!-- Mood (2x2) -->
  <div class="bento-cell cell-2x2 cell-soul reveal">
    <div class="soul-icon" aria-label="Tâm trạng">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M17.5 19H9a7 7 0 1 1 6.71-9h1.79a4.5 4.5 0 1 1 0 9Z"></path>
      </svg>
    </div>
    <div class="soul-text">Một chút mưa bay...</div>
  </div>

  <!-- Ảnh minh hoạ (2x2) -->
  <div class="bento-cell cell-2x2 cell-image reveal">
    <img src="https://images.unsplash.com/photo-1525081905268-fc0b46e9d786?q=80&w=1470&auto=format&fit=crop" alt="My Days Aesthetic" loading="lazy" />
  </div>

</section>
