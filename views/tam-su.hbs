{{!-- ═══════════════════════════════════════
     View: tam-su.hbs
     Props:
       successMessage  boolean
       publicReplies   Array<{ slug, date, displayDate, title, excerpt, tagClass, tagName }>
═══════════════════════════════════════ --}}

{{!-- ── Page header ───────────────────────────────────────── --}}
<header class="page-header page-header--centered">
  <div class="page-header-inner">



    <h1 class="page-title" data-i18n="page.tamsu.title">Tâm sự với tôi</h1>



  </div>
</header>

{{!-- ── True Bento Grid ─────────────────────────────── --}}
<section class="bento-grid container" aria-labelledby="replies-title">

  <!-- Vùng 6x4: Form tâm sự -->
  <div class="bento-cell cell-6x4 widget-confide reveal">
    <h3 class="widget-title">Gửi lời tâm sự</h3>
    {{> confide-form}}
  </div>

  <!-- Vùng 6x4: Trích dẫn Calligraphy -->
  <div class="bento-cell cell-6x4 cell-quote reveal">
    <blockquote class="random-quote">
      "Có những ngày bình yên đến mức, ta chỉ muốn ngồi lặng im nhìn mây trôi."
      <cite>— Triv.</cite>
    </blockquote>
  </div>

  <!-- Vùng 12x4: Bài hồi đáp công khai -->
  {{#if publicReplies.length}}
  <div class="bento-cell cell-12x4 reveal">
    <h2 class="widget-title" id="replies-title" data-i18n="page.tamsu.replies">Những hồi đáp công khai</h2>

    <div class="article-list tamsu-list" role="list">
      {{#each publicReplies}}
        <div class="tamsu-item reveal">
          <a href="/bai-viet/{{slug}}" class="tamsu-title">{{title}}</a>
          {{#if coverImage}}
          <img src="{{coverImage}}" alt="{{title}}" class="tamsu-thumb" loading="lazy" />
          {{/if}}
        </div>
      {{/each}}
    </div>
  </div>
  {{/if}}

</section>
