{{!-- ═══════════════════════════════════════
     View: tam-su.hbs
     Props:
       successMessage  boolean
       publicReplies   Array<{ slug, date, displayDate, title, excerpt, tagClass, tagName }>
═══════════════════════════════════════ --}}

{{!-- ── Page header ───────────────────────────────────────── --}}
<header class="page-header page-header--centered">
  <div class="page-header-inner">



    <h1 class="page-title" data-i18n="page.tamsu.title">Tâm sự với tôi</h1>



  </div>
</header>

{{!-- ── Bento Layout ─────────────────────────────── --}}
<section class="bento-container container" aria-labelledby="replies-title">
  <!-- Vùng 60%: Bài viết (ẩn ảnh) -->
  <div class="bento-col-main">
    <div class="bento-panel panel-transparent">
      <div class="section-header">
        <h2 class="section-title" id="replies-title" data-i18n="page.tamsu.replies">Những hồi đáp công khai</h2>
        <span class="section-count" aria-label="{{publicReplies.length}} bài">
          {{publicReplies.length}}
        </span>
      </div>

      <div class="article-list tamsu-list" role="list">
        {{#each publicReplies}}
          <div class="tamsu-item reveal">
            <a href="/bai-viet/{{slug}}" class="tamsu-title">{{title}}</a>
            {{#if coverImage}}
            <img src="{{coverImage}}" alt="{{title}}" class="tamsu-thumb" loading="lazy" />
            {{/if}}
          </div>
        {{/each}}
      </div>
    </div>
  </div>

  <!-- Vùng 20%: Random Quote -->
  <div class="bento-col-side">
    <div class="bento-panel widget-quote">
      <h3 class="widget-title">Trích dẫn</h3>
      <blockquote class="random-quote">
        "Có những ngày bình yên đến mức, ta chỉ muốn ngồi lặng im nhìn mây trôi."
        <cite>- Triv.</cite>
      </blockquote>
    </div>
  </div>

  <!-- Vùng 20%: Confide Form -->
  <div class="bento-col-side">
    <div class="bento-panel widget-confide">
      <h3 class="widget-title">Gửi lời tâm sự</h3>
      {{> confide-form}}
    </div>
  </div>
</section>
{{/if}}
