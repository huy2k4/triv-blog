{{!-- ═══════════════════════════════════════
     View: category.hbs
     Props:
       categoryName        string
       categoryTagClass    string  (e.g. 'tag-mydays')
       categoryDescription string
       posts               Array<{ slug, date, displayDate, title, excerpt, tagClass, tagName }>
═══════════════════════════════════════ --}}

{{!-- ── Page header ───────────────────────────────────────── --}}
<header class="page-header">
  <div class="page-header-inner">



    <h1 class="page-title" {{#if isMyDays}}data-i18n="cat.my-days"{{/if}} {{#if isGocNhin}}data-i18n="cat.goc-nhin"{{/if}} {{#if isKienThuc}}data-i18n="cat.kien-thuc"{{/if}}>{{categoryName}}</h1>



  </div>
</header>

{{!-- ── True Bento Grid ───────────────────────── --}}
<section class="bento-grid container" id="articles-section" aria-labelledby="category-articles-title">

  {{#if posts.length}}
    <!-- Bài viết nổi bật (8x4) -->
    <div class="bento-cell cell-8x4 reveal">
      <h2 class="widget-title" id="category-articles-title" data-i18n="category.featured">Nổi bật</h2>
      <a href="/bai-viet/{{posts.[0].slug}}" class="bento-article bento-article--featured">
        {{#if posts.[0].coverImage}}
        <div class="bento-article-thumb">
          <img src="{{posts.[0].coverImage}}" alt="{{posts.[0].title}}" loading="lazy" />
        </div>
        {{/if}}
        <div class="article-meta">
          <time datetime="{{posts.[0].date}}">{{posts.[0].displayDate}}</time>
          &bull; <span>{{posts.[0].tagName}}</span>
        </div>
        <h3 class="article-title">{{posts.[0].title}}</h3>
        <p class="article-excerpt">{{posts.[0].excerpt}}</p>
      </a>
    </div>

    <!-- Bộ lọc chủ đề (4x2) -->
    <div class="bento-cell cell-4x2 reveal">
      <h3 class="widget-title">Chủ đề</h3>
      <div class="tag-cloud">
        <a href="#" class="tag-badge">#tuduy</a>
        <a href="#" class="tag-badge">#sachhay</a>
        <a href="#" class="tag-badge">#kienthuc</a>
        <a href="#" class="tag-badge">#chill</a>
      </div>
    </div>

    <!-- Đọc nhiều nhất (4x2) -->
    <div class="bento-cell cell-4x2 reveal">
      <h3 class="widget-title">Đọc nhiều nhất</h3>
      <ol class="most-read-list">
        <li><a href="#">Làm sao để bớt suy nghĩ quá nhiều?</a></li>
        <li><a href="#">Sự tĩnh lặng của tâm trí</a></li>
        <li><a href="#">Cuốn sách thay đổi góc nhìn</a></li>
      </ol>
    </div>

    <!-- Ô hình ảnh trang trí (4x4) -->
    <div class="bento-cell cell-4x4 cell-image reveal">
      <img src="https://images.unsplash.com/photo-1499750310107-5fef28a66643?q=80&w=1470&auto=format&fit=crop" alt="Aesthetic" loading="lazy" />
    </div>

    <!-- Danh sách các bài còn lại (4x4) -->
    {{#each posts}}
      {{#if @index}}
      <div class="bento-cell cell-4x4 reveal">
        <a href="/bai-viet/{{slug}}" class="bento-article">
          <div class="bento-article-thumb">
            <img src="{{coverImage}}" alt="{{title}}" loading="lazy" />
          </div>
          <div class="article-meta">
            <time datetime="{{date}}">{{displayDate}}</time>
            &bull; <span>{{tagName}}</span>
          </div>
          <h3 class="article-title">{{title}}</h3>
        </a>
      </div>
      {{/if}}
    {{/each}}

    <!-- Ô hình ảnh trang trí thứ hai (4x4) để cân bằng lưới -->
    <div class="bento-cell cell-4x4 cell-image reveal">
      <img src="https://images.unsplash.com/photo-1516589178581-6cd7853177bb?q=80&w=1470&auto=format&fit=crop" alt="Coffee aesthetic" loading="lazy" />
    </div>
  {{else}}
    <!-- Empty state -->
    <div class="bento-cell cell-4x4 empty-state reveal" role="status">
      <span class="empty-ornament" aria-hidden="true">✦</span>
      <p class="empty-title" data-i18n="empty.title">Chưa có bài viết nào...</p>
      <p class="empty-description" data-i18n="empty.desc">Triv vẫn đang viết. Quay lại sau nhé.</p>
      <a href="/" class="empty-back-link" data-i18n="empty.back">← Về trang chủ</a>
    </div>
  {{/if}}

</section>
